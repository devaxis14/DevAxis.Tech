# ==================================
# DevAxis Server — Environment Variables
# ==================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/devaxis

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (Nodemailer — Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=admin@devaxis.in

# WhatsApp (optional — leave blank to skip)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_ADMIN_NUMBER=

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Admin Seed (used by npm run seed)
SEED_ADMIN_EMAIL=admin@devaxis.in
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=DevAxis Admin
